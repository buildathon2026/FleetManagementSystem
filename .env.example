# API Configuration
VITE_API_URL=https://fleet-api.onrender.com
API_PORT=8001

# Hosted OpenAI-compatible LLM for /ask/llm
# Recommended for hosted demos: Groq with a fast planner and stronger formatter.
LLM_API_KEY=gsk_your_groq_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
PLANNER_MODEL=llama-3.1-8b-instant
FORMATTER_MODEL=llama-3.3-70b-versatile
INGESTION_URL=http://localhost:8004

# Database
DATABASE_URL=postgresql://user:password@localhost/fleet_db

# ChromaDB Path
CHROMADB_PATH=/var/data/chromadb

# Environment
NODE_ENV=production
PYTHONUNBUFFERED=1
