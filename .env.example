# API Configuration
VITE_API_URL=https://fleet-api.onrender.com
API_PORT=8001

# LLM API Keys (get from Render secrets dashboard)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql://user:password@localhost/fleet_db

# ChromaDB Path
CHROMADB_PATH=/var/data/chromadb

# Environment
NODE_ENV=production
PYTHONUNBUFFERED=1
